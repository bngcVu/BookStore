в•—ВҘng SГҹв•—ГҰ 1, Phв•һв–‘Гҹв•—ВҘng Tв”ңГіn Phв”ңв•‘\",\r\n        city: \"QuГҹв•‘ВЎn 7, TP. HГҹв•—Гҙ Chв”ңВЎ Minh\"\r\n    });\r\n\r\n    const subTotal = cartItems.reduce((acc, item) => acc + (item.price * item.quantity), 0);\r\n    const shippingFee = shippingMethod === \"express\" ? 35000 : 15000;\r\n    const total = subTotal + shippingFee - 20000; // Assuming 20k discount carried over\r\n\r\n    return (\r\n        <div className=\"bg-slate-50 min-h-screen py-8\">\r\n            <div className=\"container mx-auto px-4 max-w-6xl\">\r\n                {/* Header */}\r\n                <div className=\"flex items-center gap-4 mb-8\">\r\n                    <Link href=\"/cart\">\r\n                        <Button variant=\"ghost\" size=\"icon\" className=\"rounded-full hover:bg-slate-200 w-10 h-10 transition-colors\">\r\n                            <ChevronLeft size={20} className=\"text-slate-600\" />\r\n                        </Button>\r\n                    </Link>\r\n                    <h1 className=\"text-2xl font-bold text-slate-900 tracking-tight\">Thanh toв”ңГӯn an toв”ңГЎn</h1>\r\n                    <div className=\"ml-auto flex items-center gap-2 text-green-600 bg-green-50 px-3 py-1.5 rounded-full text-xs font-semibold\">\r\n                        <ShieldCheck size={14} /> MГҹв•—Г¬i giao dГҹв•—ГҜch в”ҖГҰГҹв•—Гјu в”ҖГҰв•һв–‘Гҹв•—Гәc mв”ңГә hв”ңв”Ӯa SSL 256-bit\r\n                    </div>\r\n                </div>\r\n\r\n                <div className=\"flex flex-col lg:flex-row gap-8\">\r\n\r\n                    {/* Main Checkout Form */}\r\n                    <div className=\"w-full lg:w-2/3 space-y-6\">\r\n\r\n                        {/* 1. Address Section */}\r\n                        <section className=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-6 md:p-8 animate-in fade-in slide-in-from-bottom-4 duration-500\">\r\n                            <div className=\"flex items-center gap-3 mb-6 pb-4 border-b border-slate-100\">\r\n                                <div className=\"w-8 h-8 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold\">1</div>\r\n                                <h2 className=\"text-lg font-bold text-slate-900 flex items-center gap-2\">в”ҖГүГҹв•—ГҜa chГҹв•—Г« giao hв”ңГЎng</h2>\r\n                            </div>\r\n\r\n                            <div className=\"grid md:grid-cols-2 gap-4\">\r\n                                <div className=\"space-y-2\">\r\n                                    <label className=\"text-sm font-medium text-slate-700\">HГҹв•—Г¬ vв”ңГЎ tв”ңВ¬n</label>\r\n                                    <input type=\"text\" defaultValue={address.name} className=\"w-full h-11 px-4 border border-slate-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none\" />\r\n                                </div>\r\n                                <div className=\"space-y-2\">\r\n                                    <label className=\"text-sm font-medium text-slate-700\">SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi</label>\r\n                                    <input type=\"tel\" defaultValue={address.phone} className=\"w-full h-11 px-4 border border-slate-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none\" />\r\n                                </div>\r\n                                <div className=\"space-y-2 md:col-span-2\">\r\n                                    <label className=\"text-sm font-medium text-slate-700\">TГҹв•—Г«nh/Thв”ңГЎnh phГҹв•—ГҰ, QuГҹв•‘ВЎn/HuyГҹв•—Г§n</label>\r\n                                    <input type=\"text\" defaultValue={address.city} className=\"w-full h-11 px-4 border border-slate-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none\" />\r\n                                </div>\r\n                                <div className=\"space-y-2 md:col-span-2\">\r\n                
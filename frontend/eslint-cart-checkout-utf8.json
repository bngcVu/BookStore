                <Truck className={shippingMethod === 'standard' ? 'text-primary' : 'text-slate-400'} size={24} />\r\n                                            <div className=\"flex flex-col\">\r\n                                                <span className=\"font-semibold text-slate-900\">Giao hв”ңГЎng tiв”ңВ¬u chuГҹв•‘вҢҗn</span>\r\n                                                <span className=\"text-sm text-slate-500\">DГҹв•—в–’ kiГҹв•‘в”җn giao hв”ңГЎng trong 2-3 ngв”ңГЎy lв”ңГЎm viГҹв•—Г§c</span>\r\n                                            </div>\r\n                                        </div>\r\n                                        <span className=\"font-bold text-slate-900\">15.000в”ҖГҰ</span>\r\n                                    </div>\r\n                                </label>\r\n\r\n                                <label className={`relative flex cursor-pointer rounded-xl border p-4 shadow-sm hover:border-orange-500/50 transition-colors ${shippingMethod === 'express' ? 'border-orange-500 ring-1 ring-orange-500/20 bg-orange-50' : 'border-slate-200'}`}>\r\n                                    <input type=\"radio\" name=\"shipping\" value=\"express\" className=\"sr-only\" checked={shippingMethod === 'express'} onChange={() => setShippingMethod('express')} />\r\n                                    <div className=\"flex w-full items-center justify-between\">\r\n                                        <div className=\"flex items-center gap-3\">\r\n                                            <div className=\"relative\">\r\n                                                <Truck className={shippingMethod === 'express' ? 'text-orange-500' : 'text-slate-400'} size={24} />\r\n                                                <span className=\"absolute -top-1 -right-1 flex h-2 w-2\">\r\n                                                    <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75\"></span>\r\n                                                    <span className=\"relative inline-flex rounded-full h-2 w-2 bg-orange-500\"></span>\r\n                                                </span>\r\n                                            </div>\r\n                                            <div className=\"flex flex-col\">\r\n                                                <span className=\"font-semibold text-slate-900\">Giao hв”ңГЎng hГҹв•—Г…a tГҹв•—ГҰc (2H)</span>\r\n                                                <span className=\"text-sm text-slate-500\">ChГҹв•—Г« в”ңГӯp dГҹв•—Г‘ng tГҹв•‘Гӯi khu vГҹв•—в–’c nГҹв•—Г–i thв”ңГЎnh TP.HCM</span>\r\n                                            </div>\r\n                                        </div>\r\n                                        <span className=\"font-bold text-slate-900\">35.000в”ҖГҰ</span>\r\n                                    </div>\r\n                                </label>\r\n                            </div>\r\n                        </section>\r\n\r\n                        {/* 3. Payment Methods */}\r\n                        <section className=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-6 md:p-8 animate-in fade-in slide-in-from-bottom-4 duration-500 delay-200\">\r\n                            <div className=\"flex items-center gap-3 mb-6 pb-4 border-b border-slate-100\">\r\n                                <div className=\"w-8 h-8 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold\">3</div>\r\n                                <h2 className=\"text-lg font-bold text-slate-900 flex items-center gap-2\">Phв•һв–‘в•һГӯng thГҹв•—вҢҗc thanh toв”ңГӯn</h2>\r\n                            </div>\r\n\r\n                            <div className=\"grid gap-4\">\r\n                                <label className={`relative flex cursor-pointer rounded-xl border p-4 shadow-sm hover:border-primary/50 transition-colors ${paymentMethod === 'cod' ? 'border-primary ring-1 ring-primary/20 bg-primary/5' : 'border-slate-200'}`}>\r\n                                    <input type=\"radio\" name=\"payment\" value=\"cod\" className=\"sr-only\" checked={paymentMethod === 'cod'} onChange={() => setPaymentMethod('cod')} />\r\n                                    <div className=\"flex w-full items-center gap-3\">\r\n                                        <div className=\"w-10 h-10 rounded bg-green-100 text-green-600 flex items-center justify-center font-bold\">COD</div>\r\n                                        <div className=\"flex flex-col\">\r\n                                            <span className=\"font-semibold text-slate-900\">Thanh toв”ңГӯn khi nhГҹв•‘ВЎn hв”ңГЎng (C.O.D)</span>\r\n                                            <span className=\"text-sm text-slate-500\">Thanh toв”ңГӯn bГҹв•‘в–’ng tiГҹв•—Гјn mГҹв•‘в•–t/chuyГҹв•—Гўn khoГҹв•‘Гәn cho shipper</span>\r\n                                        </div>\r\n                                    </div>\r\n                                </label>\r\n\r\n                                <label className={`relative flex cursor-pointer rounded-xl border p-4 shadow-sm hover:border-primary/50 transition-colors ${paymentMethod === 'vnpay' ? 'border-primary ring-1 ring-primary/20 bg-primary/5' : 'border-slate-200'}`}>\r\n                                    <input type=\"radio\" name=\"payment\" value=\"vnpay\" className=\"sr-only\" checked={paymentMethod === 'vnpay'} onChange={() => setPaymentMethod('vnpay')} />\r\n                                    <div className=\"flex w-full items-center gap-3\">\r\n                                        <div className=\"w-10 h-10 rounded bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs px-1 text-center\">VNPay</div>\r\n                                        <div className=\"flex flex-col\">\r\n                                            <span className=\"font-semibold text-slate-900\">ThГҹв•‘в•— ATM / Internet Banking</span>\r\n                                            <span className=\"text-sm text-slate-500\">Cв”ңв”Өng cв”ңГӯng qua VNPAY an toв”ңГЎn, bГҹв•‘Гәo mГҹв•‘ВЎt nГҹв•—Г–i bГҹв•—Г–</span>\r\n                                        </div>\r\n                                    </div>\r\n                                </label>\r\n\r\n                                <label className={`relative flex cursor-pointer rounded-xl border p-4 shadow-sm hover:border-primary/50 transition-colors ${paymentMethod === 'momo' ? 'border-primary ring-1 ring-primary/20 bg-primary/5' : 'border-slate-200'}`}>\r\n                                    <input type=\"radio\" name=\"payment\" value=\"momo\" className=\"sr-only\" checked={paymentMethod === 'momo'} onChange={() => setPaymentMethod('momo')} />\r\n                                    <div className=\"flex w-full items-center gap-3\">\r\n                                        <div className=\"w-10 h-10 rounded bg-pink-100 text-pink-600 flex items-center justify-center font-bold text-xs\">MoMo</div>\r\n                                        <div className=\"flex flex-col\">\r\n                                            <span className=\"font-semibold text-slate-900\">Vв”ңВЎ в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ MoMo</span>\r\n                                            <span className=\"text-sm text-slate-500\">Quв”ңвҢҗt mв”ңГә QR qua app MoMo liГҹв•—Гјn tay</span>\r\n                                        </div>\r\n                                    </div>\r\n                                </label>\r\n                            </div>\r\n                        </section>\r\n\r\n                    </div>\r\n\r\n                    {/* Sidebar Order Summary */}\r\n                    <div className=\"w-full lg:w-1/3\">\r\n                        <div className=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-6 sticky top-24\">\r\n                            <h3 className=\"font-bold text-slate-900 mb-6 text-lg border-b border-slate-100 pb-4\">в”ҖГүв•һГӯn hв”ңГЎng cГҹв•—Вәa bГҹв•‘Гӯn {cartItems.length} sГҹв•‘Гәn phГҹв•‘вҢҗm</h3>\r\n\r\n                            {/* Items List (Minimized) */}\r\n                            <div className=\"space-y-4 mb-6\">\r\n                                {cartItems.map(item => (\r\n                                    <div key={item.id} className=\"flex gap-3 items-center\">\r\n                                        <div className=\"relative w-12 h-16 bg-slate-100 rounded border border-slate-200 overflow-hidden shrink-0\">\r\n                                            <Image src={item.imageUrl} alt={item.title} fill className=\"object-cover\" />\r\n                                            <span className=\"absolute -top-2 -right-2 bg-slate-500 text-white text-[10px] w-5 h-5 flex items-center justify-center rounded-full font-bold\">x{item.quantity}</span>\r\n                                        </div>\r\n                                        <div className=\"flex-1\">\r\n                                            <h4 className=\"text-sm font-medium text-slate-900 line-clamp-2\">{item.title}</h4>\r\n                                            <p className=\"text-sm text-slate-500\">{(item.price * item.quantity).toLocaleString('vi-VN')}в”ҖГҰ</p>\r\n                                        </div>\r\n                                    </div>\r\n                                ))}\r\n                            </div>\r\n\r\n                            {/* Cost Calculations */}\r\n                            <div className=\"space-y-3 mb-6 pt-4 border-t border-slate-100\">\r\n                                <div className=\"flex items-center justify-between text-slate-600 text-sm\">\r\n                                    <span>TГҹв•‘Гӯm tв”ңВЎnh</span>\r\n                                    <span className=\"font-medium text-slate-900\">{subTotal.toLocaleString('vi-VN')}в”ҖГҰ</span>\r\n                                </div>\r\n                                <div className=\"flex items-center justify-between text-slate-600 text-sm\">\r\n                                    <span>Phв”ңВЎ giao dГҹв•—ГҜch</span>\r\n                                    <span className=\"font-medium text-slate-900\">{shippingFee.toLocaleString('vi-VN')}в”ҖГҰ</span>\r\n                                </div>\r\n                                <div className=\"flex items-center justify-between text-green-600 text-sm font-medium\">\r\n                                    <span>KhuyГҹв•‘в”җn mв”ңГәi (BOOKSTORE20)</span>\r\n                                    <span>-20.000в”ҖГҰ</span>\r\n                                </div>\r\n                            </div>\r\n\r\n                            <div className=\"bg-slate-50 rounded-xl p-4 mb-6 border border-slate-100\">\r\n                                <div className=\"flex items-end justify-between\">\r\n                                    <div>\r\n                                        <span className=\"font-bold text-slate-900 block text-sm\">TГҹв•—ГІng thanh toв”ңГӯn</span>\r\n                                        <span className=\"text-xs text-slate-500\">в”ҖГүв”ңГә bao gГҹв•—Гҙm VAT</span>\r\n                                    </div>\r\n                                    <span className=\"text-2xl font-bold text-primary\">{total.toLocaleString('vi-VN')}в”ҖГҰ</span>\r\n                                </div>\r\n                            </div>\r\n\r\n                            <Button size=\"lg\" className=\"w-full text-base font-semibold h-14\" onClick={() => alert(\"ChuyГҹв•—Гўn hв•һв–‘Гҹв•—Вўng Payment Gateway. (ChГҹв•—вҢҗc nв”ҖГўng Demo)\")}>\r\n                                в”ҖГүГҹв•‘в•–t hв”ңГЎng ngay\r\n                            </Button>\r\n                            <p className=\"text-center text-xs text-slate-400 mt-4 leading-relaxed\">\r\n                                BГҹв•‘в–’ng viГҹв•—Г§c \"в”ҖГүГҹв•‘в•–t hв”ңГЎng ngay\", bГҹв•‘Гӯn в”ҖГҰГҹв•—Гҙng в”ңв•ң vГҹв•—Вўi в”ҖГүiГҹв•—Гјu khoГҹв•‘Гәn vв”ңГЎ dГҹв•—ГҜch vГҹв•—Г‘ cГҹв•—Вәa chв”ңв•‘ng tв”ңв”Өi.\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]}]
